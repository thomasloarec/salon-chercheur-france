{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/ville/villepinte",
      "destination": "/ville/paris",
      "permanent": true
    },
    {
      "source": "/ville/villepinte/:year",
      "destination": "/ville/paris/:year",
      "permanent": true
    },
    {
      "source": "/ville/chassieu",
      "destination": "/ville/lyon",
      "permanent": true
    },
    {
      "source": "/ville/chassieu/:year",
      "destination": "/ville/lyon/:year",
      "permanent": true
    },
    {
      "source": "/ville/bruz",
      "destination": "/ville/rennes",
      "permanent": true
    },
    {
      "source": "/ville/bruz/:year",
      "destination": "/ville/rennes/:year",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap-exposants.xml",
      "destination": "https://vxivdvzzhebobveedxbj.supabase.co/functions/v1/sitemap-exposants"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap(.*).xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}