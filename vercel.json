{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets|favicon|logos|robots\\.txt|sitemap\\.xml|llms\\.txt|llms-full\\.txt|api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
